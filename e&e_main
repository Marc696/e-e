    const parseACTag = (str: string) => {
        const m = str.match(/\[AC=([^\]]+)\]/)
        if (!m) return null
        const raw = m[1]
        const noarmor = raw.includes("|noarmor")
        const core = raw.replace("|noarmor", "")
        
        console.log("parseACTag input:", str)
        console.log("parseACTag raw:", raw, "core:", core, "noarmor:", noarmor)
        
        if (core.startsWith("+")) {
            const val = parseInt(core.slice(1))
            const result = !isNaN(val) ? { type: "bonus" as const, value: val, noarmor } : null
            console.log("parseACTag result (bonus):", result)
            return result
        }
        if (core.includes("+DEX2")) {
            const base = parseInt(core.replace("+DEX2", ""))
            const result = !isNaN(base) ? { type: "med" as const, base, noarmor } : null
            console.log("parseACTag result (med):", result)
            return result
        }
        if (core.includes("+DEX")) {
            const base = parseInt(core.replace("+DEX", ""))
            const result = !isNaN(base) ? { type: "light" as const, base, noarmor } : null
            console.log("parseACTag result (light):", result)
            return result
        }
        const n = parseInt(core)
        const result = !isNaN(n) ? { type: "fixed" as const, base: n, noarmor } : null
        console.log("parseACTag result (fixed):", result)
        return result
    }

