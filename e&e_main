            if (tag) {
                // Skip noarmor items if wearing armor
                if (tag.noarmor && hasArmorEquipped) {
                    console.log("  Skipped (noarmor restriction + wearing armor)")
                    return
                }
                
                if (tag.type === "bonus") {
                    // AC bonus (like shields): always add
                    totalBonus += tag.value
                    console.log("  Added AC bonus:", tag.value, "(total bonus:", totalBonus, ")")
                } else if (!hasArmorEquipped) {
                    // Alternative AC calculation (only if not wearing armor)
