function abilityNameToKey(name: string): keyof typeof races["Humano"] { // maps ES name -> internal keys
    const n = String(name || "")
    if (n === "Fuerza") return "str"
    if (n === "Destreza") return "dex"
    if (n === "Constitución") return "con"
    if (n === "Inteligencia") return "int"
    if (n === "Sabiduría") return "wis"
    return "cha"
}

function getSubraceBonus(race: string, subrace: string) {
    const rule = subraceRules[`${race}|${subrace}`]
    const out = { str: 0, dex: 0, con: 0, int: 0, wis: 0, cha: 0 }
    if (!rule) return out
    for (const [k, v] of Object.entries(rule.mejora_caracteristica || {})) {
        const key = abilityNameToKey(k)
        out[key] += Number(v) || 0
    }
    return out
}

