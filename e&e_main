                                                                    headers: {
                                                                        apikey: supabaseAnonKey,
                                                                        Authorization: `Bearer ${accessToken}`,
                                                                    },
                                                                }
                                                            )
                                                            if (!res.ok) return
                                                            
                                                            const data = await res.json()
                                                            if (!data || data.length === 0) return
                                                            
                                                            const session = data[0]
                                                            const updatedMonsters = (session.monsters || []).map((m, i) =>
                                                                i === idx ? { ...m, hp: Math.min(Number(m.maxHp), Number(m.hp) + 1) } : m
                                                            )
                                                            
                                                            startTransition(() => {
                                                                setCombatMonsters(updatedMonsters)
                                                            })
                                                            
                                                            await fetch(
                                                                `${cleanSupabaseUrl}/rest/v1/combat_sessions?code=eq.${activeCombatSession}`,
                                                                {
                                                                    method: "PATCH",
                                                                    headers: {
                                                                        apikey: supabaseAnonKey,
                                                                        Authorization: `Bearer ${accessToken}`,
                                                                        "Content-Type": "application/json",
                                                                        Prefer: "return=minimal",
                                                                    },
                                                                    body: JSON.stringify({ 
                                                                        monsters: updatedMonsters,
                                                                        players: session.players || []
                                                                    }),
                                                                }
                                                            )
                                                        } catch (error) {
                                                            console.error("Error updating monster HP:", error)
                                                        }
                                                    }}
                                                >
                                                    +
                                                </button>
                                            </div>
                                        )}
                                    </div>
                                )
                            })}
                        </div>

                        {/* Players */}
                        <div>
                            <div style={{ ...labelFont, fontSize: "12px", fontWeight: 700, marginBottom: "8px" }}>Jugadores</div>
                            {combatPlayers.filter(p => p.userId !== userId).map((player, idx) => (
                                <div key={idx} style={{ ...sectionStyle, marginBottom: "8px", padding: "12px" }}>
                                    <div style={{ ...bodyFont, fontSize: "14px", fontWeight: 700, marginBottom: "4px" }}>
                                        {player.name}
                                    </div>
                                    <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
                                        <div style={{ flex: 1, backgroundColor: backgroundColor, borderRadius: "4px", height: "24px", overflow: "hidden" }}>
                                            <div
                                                style={{
                                                    height: "100%",
                                                    backgroundColor: "#5CB85C",
                                                    width: `${(player.hp / player.maxHp) * 100}%`,
                                                    transition: "width 0.3s ease",
                                                }}
                                            />
                                        </div>
                                        <div style={{ ...labelFont, fontSize: "11px", minWidth: "60px", textAlign: "right" }}>
                                            {player.hp}/{player.maxHp}
                                        </div>
                                    </div>
                                </div>
                            ))}
                            {/* My Player HP Bar - Inside Jugadores section */}
                            {(() => {
                                const myPlayer = combatPlayers.find(p => p.userId === userId)
                                if (!myPlayer || dmMode) return null
                                return (
                                    <div style={{ ...sectionStyle, marginBottom: "8px", padding: "12px", backgroundColor: accentColor }}>
                                        <div style={{ ...bodyFont, fontSize: "14px", fontWeight: 700, marginBottom: "4px" }}>
                                            {myPlayer.name} (Tú)
                                        </div>
                                        <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
                                            <div style={{ flex: 1, backgroundColor: backgroundColor, borderRadius: "4px", height: "24px", overflow: "hidden" }}>
                                                <div
                                                    style={{
                                                        height: "100%",
                                                        backgroundColor: "#5CB85C",
                                                        width: `${(myPlayer.hp / myPlayer.maxHp) * 100}%`,
                                                        transition: "width 0.3s ease",
                                                    }}
                                                />
                                            </div>
                                            <div style={{ ...labelFont, fontSize: "11px", minWidth: "60px", textAlign: "right" }}>
                                                {myPlayer.hp}/{myPlayer.maxHp}
                                            </div>
                                        </div>
                                        <div style={{ display: "flex", gap: "8px", marginTop: "8px" }}>
                                            <button
                                                style={{ ...buttonStyle, flex: 1 }}
                                                onClick={async () => {
                                                    try {
                                                        // 1. Fetch current complete state
                                                        const res = await fetch(
                                                            `${cleanSupabaseUrl}/rest/v1/combat_sessions?code=eq.${activeCombatSession}&select=*`,
                                                            {
                                                                headers: {
                                                                    apikey: supabaseAnonKey,
                                                                    Authorization: `Bearer ${accessToken}`,
                                                                },
                                                            }
                                                        )
                                                        if (!res.ok) return
                                                        
                                                        const data = await res.json()
                                                        if (!data || data.length === 0) return
                                                        
                                                        const session = data[0]
                                                        
                                                        // 2. Create immutable copy with updated player HP
                                                        const updatedPlayers = (session.players || []).map(p =>
                                                            p.userId === userId ? { ...p, hp: Math.max(0, Number(p.hp) - 1) } : p
                                                        )
                                                        
                                                        const newHP = updatedPlayers.find(p => p.userId === userId)?.hp || 0
                                                        
                                                        // 3. Update local state
                                                        startTransition(() => {
                                                            setCombatPlayers(updatedPlayers)
                                                            setCurrentHP(newHP)
                                                        })
                                                        
                                                        // 4. Write complete state back
                                                        await fetch(
                                                            `${cleanSupabaseUrl}/rest/v1/combat_sessions?code=eq.${activeCombatSession}`,
                                                            {
                                                                method: "PATCH",
                                                                headers: {
                                                                    apikey: supabaseAnonKey,
                                                                    Authorization: `Bearer ${accessToken}`,
                                                                    "Content-Type": "application/json",
                                                                    Prefer: "return=minimal",
                                                                },
                                                                body: JSON.stringify({ 
                                                                    players: updatedPlayers,
                                                                    monsters: session.monsters || []
                                                                }),
                                                            }
                                                        )
                                                    } catch (error) {
                                                        console.error("Error updating HP:", error)
                                                    }
                                                }}
                                            >
                                                −
                                            </button>
                                            <button
                                                style={{ ...buttonStyle, flex: 1 }}
                                                onClick={async () => {
                                                    try {
                                                        // 1. Fetch current complete state
                                                        const res = await fetch(
                                                            `${cleanSupabaseUrl}/rest/v1/combat_sessions?code=eq.${activeCombatSession}&select=*`,
                                                            {
                                                                headers: {
                                                                    apikey: supabaseAnonKey,
                                                                    Authorization: `Bearer ${accessToken}`,
                                                                },
                                                            }
                                                        )
                                                        if (!res.ok) return
                                                        
                                                        const data = await res.json()
                                                        if (!data || data.length === 0) return
                                                        
                                                        const session = data[0]
                                                        
                                                        // 2. Create immutable copy with updated player HP
                                                        const updatedPlayers = (session.players || []).map(p =>
                                                            p.userId === userId ? { ...p, hp: Math.min(Number(p.maxHp), Number(p.hp) + 1) } : p
                                                        )
                                                        
                                                        const newHP = updatedPlayers.find(p => p.userId === userId)?.hp || 0
                                                        
                                                        // 3. Update local state
                                                        startTransition(() => {
                                                            setCombatPlayers(updatedPlayers)
                                                            setCurrentHP(newHP)
                                                        })
                                                        
                                                        // 4. Write complete state back
                                                        await fetch(
                                                            `${cleanSupabaseUrl}/rest/v1/combat_sessions?code=eq.${activeCombatSession}`,
                                                            {
                                                                method: "PATCH",
                                                                headers: {
                                                                    apikey: supabaseAnonKey,
                                                                    Authorization: `Bearer ${accessToken}`,
                                                                    "Content-Type": "application/json",
                                                                    Prefer: "return=minimal",
                                                                },
                                                                body: JSON.stringify({ 
                                                                    players: updatedPlayers,
                                                                    monsters: session.monsters || []
                                                                }),
                                                            }
                                                        )
                                                    } catch (error) {
                                                        console.error("Error updating HP:", error)
                                                    }
                                                }}
                                            >
                                                +
                                            </button>
                                        </div>
                                    </div>
                                )
                            })()}
                        </div>
                    </div>
                )}
            </div>

            {/* Armor Modal */}
            {armorModalOpen && (
                <div style={modalOverlayStyle} onClick={() => setArmorModalOpen(false)}>
                    <div style={modalContentStyle} onClick={(e) => e.stopPropagation()}>
                        <button style={modalCloseButtonStyle} onClick={() => setArmorModalOpen(false)}>×</button>
                        <div style={{ ...headingFont, fontSize: "18px", fontWeight: 700, textTransform: "uppercase" }}>
                            CLASE DE ARMADURA
                        </div>
                        <div style={{ ...abilityValueStyle, fontSize: "64px" }}>{armorClass}</div>
                        {(wornArmorIndex !== null && armors[wornArmorIndex]) || equippedItems.size > 0 ? (
                            <div style={{ ...labelFont, fontSize: "11px", opacity: 0.85, textAlign: "center", marginBottom: "4px", maxWidth: "100%" }}>
                                {wornArmorIndex !== null && armors[wornArmorIndex] && (
                                    <div style={{ marginBottom: "8px" }}>
                                        <div style={{ fontWeight: 700, marginBottom: "2px" }}>Armadura equipada:</div>
                                        <div>{armors[wornArmorIndex]}</div>
                                    </div>
                                )}
                                {(() => {
                                    const bonusItems: Array<{ name: string; bonus: number }> = []
                                    equippedItems.forEach(idx => {
                                        if (idx >= items.length) return
                                        const itemStr = items[idx]
                                        const tag = parseACTag(itemStr)
                                        if (tag && tag.type === "bonus") {
                                            bonusItems.push({ name: itemStr, bonus: tag.value })
                                        } else {
                                            const match = itemStr.toLowerCase().match(/\+([123])\s*(ca|ac|armadura|armor)/i)
                                            if (match) {
                                                bonusItems.push({ name: itemStr, bonus: parseInt(match[1]) })
                                            }
                                        }
                                    })
                                    if (bonusItems.length > 0) {
                                        const totalBonus = bonusItems.reduce((sum, item) => sum + item.bonus, 0)
                                        return (
                                            <div style={{ marginTop: "8px" }}>
                                                <div style={{ fontWeight: 700, marginBottom: "2px" }}>Objetos equipados (+{totalBonus} CA):</div>
                                                {bonusItems.map((item, i) => (
                                                    <div key={i} style={{ marginTop: "2px" }}>
                                                        • {item.name} (+{item.bonus})
                                                    </div>
                                                ))}
                                            </div>
                                        )
                                    }
                                    return null
                                })()}
                            </div>
                        ) : (
                            <div style={{ ...labelFont, fontSize: "11px", opacity: 0.85, textAlign: "center", marginBottom: "4px" }}>
                                CA base: 10 + Modificador de Destreza ({modifiers.dex >= 0 ? `+${modifiers.dex}` : modifiers.dex})
                            </div>
                        )}
                        <button
                            style={{ ...modalApplyButtonStyle, width: "100%" }}
                            onClick={() => setArmorModalOpen(false)}
                        >
                            Cerrar
                        </button>
                    </div>
                </div>
            )}

            {/* Modal */}
            {modalOpen && modalAbility && (
                <div style={modalOverlayStyle} onClick={closeModal}>
                    <div
                        style={modalContentStyle}
                        onClick={(e) => e.stopPropagation()}
                    >
                        <button
                            style={modalCloseButtonStyle}
                            onClick={closeModal}
                        >
                            ×
                        </button>
                        <div
                            style={{
                                ...headingFont,
                                fontSize: "18px",
                                fontWeight: 700,
                                textTransform: "uppercase",
                            }}
                        >
                            {modalAbility === "str" && "FUERZA"}
                            {modalAbility === "dex" && "DESTREZA"}
                            {modalAbility === "con" && "CONSTITUCIÓN"}
                            {modalAbility === "int" && "INTELIGENCIA"}
                            {modalAbility === "wis" && "SABIDURÍA"}
                            {modalAbility === "cha" && "CARISMA"}
                        </div>
                        <div style={{ ...abilityValueStyle, fontSize: "64px" }}>
                            {modalValue}
                        </div>
                        <div style={modalButtonContainerStyle}>
                            <button
                                style={modalCircleButtonStyle}
                                onClick={() => adjustModalValue(-1)}
                            >
                                −
                            </button>
                            <button
                                style={modalCircleButtonStyle}
                                onClick={() => adjustModalValue(1)}
                            >
                                +
                            </button>
                        </div>
                        {(() => {
                            const parts = getAbilityBonusInfo(modalAbility)
                            if (!parts.length) return null
                            return (
                                <div
                                    style={{
                                        ...labelFont,
                                        fontSize: "11px",
                                        opacity: 0.85,
                                        width: "100%",
                                        textAlign: "center",
                                    }}
                                >
                                    Bonos aplicados: {parts.join(" · ")}
                                </div>
                            )
                        })()}
                        <button
                            style={{ ...modalApplyButtonStyle, width: "100%" }}
                            onClick={applyModalValue}
                        >
                            Aplicar
                        </button>
                    </div>
                </div>
            )}

            {/* Toast */}
            <div style={toastStyle}>{toastMessage}</div>

            {/* Loading overlay (no portal) */}
            {initLoading && (
                <div
                    style={{
                        position: "fixed",
                        inset: 0,
                        width: "100vw",
                        height: "100%",
                        zIndex: 3000,
                        backgroundColor: "rgba(0, 0, 0, 0.6)",
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "center",
                        padding: "24px",
                    }}
                    role="alert"
                    aria-live="polite"
                >
                    <div
                        style={{
                            backgroundColor: primaryColor,
                            border: `1px solid ${borderColor}`,
                            borderRadius: "12px",
                            padding: "20px",
                            width: "100%",
                            maxWidth: "420px",
                            textAlign: "center",
                            boxShadow: "0 10px 30px rgba(0, 0, 0, 0.35)",
                        }}
                    >
                        <div
                            style={{
                                width: 28,
                                height: 28,
                                borderRadius: "50%",
                                border: `3px solid ${borderColor}`,
                                borderTopColor: accentColor,
                                margin: "0 auto 12px",
                                animation: "dndSpin 1s linear infinite",
                            }}
                        />
                        {loaderVideoFile ? (
                            <video
                                src={loaderVideoFile}
                                style={{
                                    width: "100%",
                                    height: "auto",
                                    maxHeight: "200px",
                                    borderRadius: "10px",
                                    objectFit: "contain",
                                    margin: "0 auto 12px",
                                    mixBlendMode: loaderVideoBlendMode as any,
                                    display: "block",
                                }}
                                autoPlay
                                loop
                                muted
                                playsInline
                            />
                        ) : null}
                        <div
                            style={{
                                ...headingFont,
                                fontSize: "14px",
                                fontWeight: 700,
                                textTransform: "uppercase",
                                marginBottom: "6px",
                            }}
                        >
                            Cargando...
                        </div>
                        <div style={{ ...bodyFont, fontSize: "13px", lineHeight: 1.4 }}>
                            {getInitLoadingMessage}
                        </div>
                    </div>
                    <style>{`@keyframes dndSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>
                </div>
            )}
        </div>
    )
}



