function normalizeChoiceName(str: string) {
    return String(str || "")
        .trim()
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\./g, "")
        .replace(/\s+/g, " ")
}

function baseSkillLabel(skillDisplayName: string) {
    const m = String(skillDisplayName || "").match(/^(.+?)(\([^)]+\))$/)
    return (m ? m[1] : String(skillDisplayName || "")).trim()
}

function formatBonusLine(bonuses: { str: number; dex: number; con: number; int: number; wis: number; cha: number }) {
    const parts: string[] = []
    if (bonuses.str) parts.push(`${bonuses.str > 0 ? "+" : ""}${bonuses.str} FUE`)
    if (bonuses.dex) parts.push(`${bonuses.dex > 0 ? "+" : ""}${bonuses.dex} DES`)
    if (bonuses.con) parts.push(`${bonuses.con > 0 ? "+" : ""}${bonuses.con} CON`)
    if (bonuses.int) parts.push(`${bonuses.int > 0 ? "+" : ""}${bonuses.int} INT`)
    if (bonuses.wis) parts.push(`${bonuses.wis > 0 ? "+" : ""}${bonuses.wis} SAB`)
    if (bonuses.cha) parts.push(`${bonuses.cha > 0 ? "+" : ""}${bonuses.cha} CAR`)
    return parts.length ? parts.join(" · ") : "—"
}

function toUnicodeBold(input: string) {
    const out: string[] = []
    for (const ch of input) {
        const code = ch.codePointAt(0) ?? 0
        // A-Z
        if (code >= 65 && code <= 90) {
            out.push(String.fromCodePoint(0x1d400 + (code - 65)))
            continue
        }
        // a-z
        if (code >= 97 && code <= 122) {
            out.push(String.fromCodePoint(0x1d41a + (code - 97)))
            continue
        }
        // 0-9
        if (code >= 48 && code <= 57) {
            out.push(String.fromCodePoint(0x1d7ce + (code - 48)))
            continue
        }
        out.push(ch)
    }
    return out.join("")
}

function extractACTag(it: any): string {
    const descRaw = it?.descripcion || it?.description || it?.desc || ""
    const desc = String(Array.isArray(descRaw) ? descRaw.join(" ") : descRaw).toLowerCase()
    const nameRaw = it?.name || it?.nombre_espanol || it?.nombre || it?.titulo || ""
    const name = String(nameRaw).toLowerCase()
    const caNum = it?.ca ?? it?.clase_armadura ?? it?.armor_class ?? it?.armor_ca
    if (caNum != null && !isNaN(Number(caNum)) && Number(caNum) >= 10) {
        const n = Number(caNum)
        const hasDex = /destreza|dexterity/.test(desc)
        const hasMax2 = /m[aá]ximo[^.]{0,20}\+?2|max(\.|\s)[^.]{0,15}2/.test(desc)
        if (hasDex && hasMax2) return `[AC=${n}+DEX2]`
        if (hasDex) return `[AC=${n}+DEX]`
        return `[AC=${n}]`
    }
    const noArmorDexMatch = desc.match(/(?:sin\s+armadura|no\s+llev[aá]s?\s+armadura|no\s+est[aá]s?\s+usando)[^.]{0,60}ca\s+(?:es\s+)?(\d+)[^.]{0,30}destreza/i) || desc.match(/ca\s+(?:es\s+)?(\d+)[^.]{0,30}destreza[^.]{0,60}(?:sin\s+armadura|no\s+llev)/i)
    if (noArmorDexMatch) return `[AC=${noArmorDexMatch[1]}+DEX|noarmor]`
    const noArmorFixedMatch = desc.match(/(?:sin\s+armadura|no\s+llev[aá]s?\s+armadura|no\s+est[aá]s?\s+usando)[^.]{0,60}ca\s+(?:es\s+)?(\d+)/i) || desc.match(/ca\s+(?:es\s+)?(\d+)[^.]{0,60}(?:sin\s+armadura|no\s+llev)/i)
    if (noArmorFixedMatch) return `[AC=${noArmorFixedMatch[1]}|noarmor]`
    const medMatch = desc.match(/ca\s+(\d+)\s*\+\s*modificador[^.]{0,30}destreza[^.]{0,30}m[aá]ximo[^.]{0,10}\+?2/i) || desc.match(/ca\s+(\d+)[^.]{0,50}destreza[^.]{0,30}(?:m[aá]ximo|hasta)[^.]{0,10}[+]?2/i)
    if (medMatch) return `[AC=${medMatch[1]}+DEX2]`
    const lightMatch = desc.match(/ca\s+(\d+)\s*\+\s*(?:modificador\s+(?:de\s+)?)?destreza/i)
    if (lightMatch) return `[AC=${lightMatch[1]}+DEX]`
    const fixedMatch = desc.match(/(?:ca|clase\s+de\s+armadura)\s+(?:de\s+)?(\d+)/i)
    if (fixedMatch) { const n = parseInt(fixedMatch[1]); if (n >= 10 && n <= 22) return `[AC=${n}]` }
    const bonusMatch = desc.match(/\+\s*(\d)\s*(?:a\s+(?:la\s+)?)?(?:ca\b|clase\s+de\s+armadura)/i) || desc.match(/ca[^.]{0,20}\+\s*(\d)\b/i)
    if (bonusMatch) return `[AC=+${bonusMatch[1]}]`
    if ((name.includes("escudo") || name.includes("shield")) && !name.includes("hechizo") && !name.includes("spell")) return "[AC=+2]"
    return ""
}

