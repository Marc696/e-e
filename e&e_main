    const parseEquipmentTextForPrefetch = (text: string): any[] => {
        if (!text) return []
        try {
            const parsed = JSON.parse(text)
            if (Array.isArray(parsed)) return parsed
            if (parsed && typeof parsed === "object") {
                for (const key of Object.keys(parsed as any)) {
                    const val = (parsed as any)[key]
                    if (Array.isArray(val)) return val
                }
            }
        } catch (e) {
            // ignore
        }

        // regex recovery for truncated/invalid JSON: extract { "name": "..." }
        const recovered: any[] = []
        const re = /\{\s*"name"\s*:\s*"([^"]+)"\s*\}/g
        let m: RegExpExecArray | null = null
        while ((m = re.exec(text))) {
            recovered.push({ name: m[1] })
        }
        return recovered
    }

