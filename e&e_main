    const renderEquipmentView = () => {
        const normalize = (str: string) => {
            if (!str) return ""
            return str
                .trim()
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/[^a-z0-9\s]/g, "")
                .replace(/\s+/g, " ")
        }

        const parseEquipmentText = (text: string): any[] => {
            if (!text) return []

            // 1) Try direct JSON
            try {
                const parsed = JSON.parse(text)
                if (Array.isArray(parsed)) return parsed
                if (Array.isArray((parsed as any)?.results)) return (parsed as any).results

                // Root object support: return first key whose value is an array
                if (parsed && typeof parsed === "object") {
                    for (const key of Object.keys(parsed as any)) {
                        const val = (parsed as any)[key]
                        if (Array.isArray(val)) return val
                    }
                }
            } catch (e) {
                // ignore
            }

            // 2) Try split by underscore separators (similar to dados_efecto repo format)
            const sections = text.split(/_{5,}/)
            const combined: any[] = []
            for (const section of sections) {
                const trimmed = section.trim()
                if (!trimmed.startsWith("[")) continue
                try {
                    const parsed = JSON.parse(trimmed)
                    if (Array.isArray(parsed)) combined.push(...parsed)
                } catch (e) {
                    console.warn("Equip: error parsing section", e)
                }
            }
            if (combined.length) return combined

            // 3) Best-effort: try to find a JSON array inside the file
            const start = text.indexOf("[")
            const end = text.lastIndexOf("]")
            if (start >= 0 && end > start) {
                try {
                    const sliced = text.slice(start, end + 1)
                    const parsed2 = JSON.parse(sliced)
                    if (Array.isArray(parsed2)) return parsed2
                } catch (e) {
                    console.warn("Equip: failed to parse JSON slice", e)
                }
            }

            // 4) NDJSON fallback
            const lines = text
                .split(/\r?\n/)
                .map((l) => l.trim())
                .filter(Boolean)
            if (lines.length > 0 && lines.every((l) => l.startsWith("{"))) {
                const out: any[] = []
                for (const line of lines) {
                    try {
                        out.push(JSON.parse(line))
                    } catch (e) {
                        // ignore
                    }
                }
                return out
            }

            // 5) Regex recovery for truncated/invalid JSON: extract { "name": "..." }
            const recovered: any[] = []
            const re = /{\\s*"name"\\s*:\\s*"([^\\"]+)"\\s*}/g
            let m: RegExpExecArray | null = null
            while ((m = re.exec(text))) {
                recovered.push({ name: m[1] })
            }
            if (recovered.length) return recovered

            return []
